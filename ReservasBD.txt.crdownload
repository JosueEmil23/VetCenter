-- Crear la base de datos aislada para las citas
CREATE DATABASE IF NOT EXISTS bd_veterinaria_reservas


USE bd_veterinaria_reservas;

-- Crear tabla de Reservas
CREATE TABLE IF NOT EXISTS reservas (
    id INT AUTO_INCREMENT PRIMARY KEY,
    fecha_hora DATETIME NOT NULL,
    motivo VARCHAR(255) NOT NULL,
    mascota_id INT NOT NULL -- ID entero que se validará vía OpenFeign en Java
) ENGINE=InnoDB;